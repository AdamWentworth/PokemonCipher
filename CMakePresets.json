{
  "version": 4,
  "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
  "configurePresets": [
    {
      "name": "vs2026",
      "displayName": "Visual Studio 18 2026 x64 (vcpkg)",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/dev/vcpkg/scripts/buildsystems/vcpkg.cmake",

        "VCPKG_MANIFEST_DIR": "${sourceDir}",
        "VCPKG_INSTALLED_DIR": "C:/dev/vcpkg/installed",

        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "vs2026", "configuration": "Debug" },
    { "name": "release", "configurePreset": "vs2026", "configuration": "Release" }
  ]
}
